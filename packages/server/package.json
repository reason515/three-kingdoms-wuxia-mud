{
  "name": "@hanmo/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:reset": "tsx src/db/reset.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@hanmo/content": "workspace:*",
    "@libsql/client": "^0.17.4",
    "drizzle-orm": "^0.40.1"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "vitest": "^3.1.1"
  }
}
